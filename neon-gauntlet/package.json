{
  "name": "neon-gauntlet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "vite --host 127.0.0.1 --port 4177",
    "dev": "vite --host 127.0.0.1 --port 4177",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4177",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:assets": "node tools/validate-contact-sheets.mjs",
    "boss-sheets": "node tools/generate-boss-sheets.mjs",
    "enemy-role-sheets": "node tools/generate-enemy-role-sheets.mjs",
    "test:maps": "node tools/inspect-map-art.mjs --check --all",
    "test:map-art": "node tools/validate-map-art.mjs",
    "test:audio": "node tools/validate-audio-sources.mjs",
    "test:release": "node tools/check-release-readiness.mjs",
    "release:check": "node tools/check-release-readiness.mjs --strict",
    "test:review-packets": "node tools/validate-review-packets.mjs",
    "test:levels": "node tools/validate-level-production-plan.mjs",
    "inspect:map": "node tools/inspect-map-art.mjs",
    "create:level": "node tools/create-level-from-template.mjs",
    "capture:map": "node tools/capture-map-preview.mjs",
    "test:screenshots": "playwright test tests/e2e/visual.spec.ts",
    "update:screenshots": "playwright test tests/e2e/visual.spec.ts --update-snapshots",
    "contact-sheets": "node tools/generate-contact-sheets.mjs",
    "serve:legacy": "node serve.mjs"
  },
  "dependencies": {
    "phaser": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  }
}
